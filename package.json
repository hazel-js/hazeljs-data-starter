{
  "name": "hazeljs-data-starter",
  "version": "1.0.0",
  "description": "Real-world example showcasing @hazeljs/data - ETL pipelines, Schema validation, Stream processing",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "run:sample": "ts-node src/scripts/run-sample-pipelines.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "@hazeljs/core": "0.2.0-beta.38",
    "@hazeljs/data": "0.2.0-beta.38",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.50",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "hazeljs",
    "data",
    "etl",
    "pipeline",
    "validation",
    "starter"
  ],
  "author": "HazelJS",
  "license": "Apache-2.0"
}
